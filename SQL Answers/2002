with cte as (
select user_id, sum(case when type = 'Refinance' then 1 else 0 end) as refinance_cnt,
sum(case when type = 'InSchool' then 1 else 0 end) as inschool_cnt
from loans
group by user_id 
having sum(case when type = 'Refinance' then 1 else 0 end) >=1
and sum(case when type = 'InSchool' then 1 else 0 end) >=1
)
select user_id 
from cte
